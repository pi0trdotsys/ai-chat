# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# Długi losowy string (min. 32 znaki) — możesz wygenerować: openssl rand -base64 32
JWT_SECRET=zmien-na-dlugi-losowy-string

# Hasło dostępu do czatu
ACCESS_PASSWORD=twoje-haslo

# URL frontendu (domena publiczna)
FRONTEND_URL=https://ai.twoja-domena.pl
